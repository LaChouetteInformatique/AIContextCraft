# ================================================================= #
# Optimized .gitignore for Python Projects                          #
# Generated by Gemini, based on the "AI Context Craft" project      #
# ================================================================= #

# --- Virtual Environments ---
# Never commit local dependencies.
venv/
.venv/
env/
.env/
*_env/
env.bak/
venv.bak/

# --- Python Bytecode and Cache Files ---
# These files are generated at runtime.
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# --- Build and Distribution Folders ---
# These folders contain build and packaging artifacts.
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
develop-eggs/
*.egg-info/

# --- Files Generated by the "AI Context Craft" Project ---
# Ignore the default outputs of the tool itself.
*.log
project_files_*.txt
project_tree_*.txt
concat_*.txt
# If you use a custom output folder, add it here.
# e.g., my_output_folder/

# --- Local Configuration and Secret Files ---
# .env files contain secrets and should never be committed.
# The !.env.example allows committing an example file.
.env
.env.*
!.env.example

# --- IDE and Editor Configuration Files ---
# Developer-specific environment settings.
.idea/
.vscode/
.project
.settings/
*.sublime-workspace
*.sublime-project

# --- Test and Code Coverage Files ---
# Artifacts generated by testing tools.
.pytest_cache/
.tox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
htmlcov/
.hypothesis/

# --- JavaScript Dependencies (if applicable) ---
# Mentioned in the project's test files.
node_modules/
npm-debug.log
yarn-error.log

# --- System Files (macOS, Windows, Linux) ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*~
*.swp