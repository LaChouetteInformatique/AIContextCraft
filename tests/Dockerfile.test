# Dockerfile for AI Context Craft Test Runner
FROM python:3.9-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    docker.io \
    git \
    bash \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install Python test dependencies
RUN pip install --no-cache-dir \
    pytest==7.4.0 \
    pytest-cov==4.1.0 \
    pytest-timeout==2.1.0 \
    pytest-xdist==3.3.1 \
    pytest-html==3.2.0 \
    click==8.1.3 \
    rich==13.5.2 \
    pyyaml==6.0 \
    docker==6.1.3 \
    requests==2.31.0

# Create directory structure
RUN mkdir -p /app/tests /app/utils

# Set Python path
ENV PYTHONPATH=/app

# Default command
CMD ["python", "/app/tests/test_runner.py", "--help"]